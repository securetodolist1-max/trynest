# Security Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production_12345

# SMTP Configuration (Required for registration and login OTP)
# For Gmail: Use your Gmail address and an "App Password" (2FA enabled required)
# Get App Password: https://myaccount.google.com/apppasswords
# For other providers: Use your email and SMTP password
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Database Configuration  
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres_secure_password_2024
DATABASE_NAME=securitydb
